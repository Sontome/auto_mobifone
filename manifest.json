{
  "manifest_version": 3,
  "name": "MobiFone Promo Checker",
  "description": "Extension kiểm tra gói khuyến mãi theo danh sách số điện thoại.",
  "version": "1.0.0",
  "action": {
    "default_title": "MobiFone Promo Checker",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://10.3.17.135:9009/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://10.3.17.135:9009/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
