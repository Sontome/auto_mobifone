
{
  "manifest_version": 2,
  "name": "MobiFone Promo Checker",
  "description": "Extension kiểm tra gói khuyến mãi theo danh sách số điện thoại.",
  "version": "1.0.0",

  "browser_action": {
    "default_title": "MobiFone Promo Checker",
    "default_popup": "popup.html"
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "http://10.3.17.135:9009/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "http://10.3.17.135:9009/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "mobifone-checker@example.com",
      "strict_min_version": "109.0"
    }
  }
}

